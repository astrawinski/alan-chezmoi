{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
set -eu

repo_dir="${HOME}/{{ .repos.checkout_root }}/cavekit-codex"

if [ ! -d "${repo_dir}/skills" ]; then
  if [ -x "${HOME}/.local/bin/sync-user-repos" ]; then
    printf '[chezmoi] cavekit-codex checkout is not present yet; syncing managed repos first.\n' >&2
    "${HOME}/.local/bin/sync-user-repos" || true
  fi
fi

if [ ! -d "${repo_dir}/skills" ]; then
  printf '[chezmoi] cavekit-codex skills surface is not present yet after repo sync; skipping Codex Cavekit install.\n' >&2
  exit 0
fi

skills_bin="${HOME}/.local/npm/bin/skills"

if [ ! -x "${skills_bin}" ] && ! command -v skills >/dev/null 2>&1; then
  printf '[chezmoi] skills CLI is not installed yet; skipping Codex Cavekit install.\n' >&2
  exit 0
fi

if [ ! -x "${skills_bin}" ]; then
  skills_bin="$(command -v skills)"
fi

printf '[chezmoi] Installing cavekit-codex skills into Codex from %s\n' "${repo_dir}" >&2
"${skills_bin}" add "${repo_dir}" -g -a codex -y --skill '*'
{{ end -}}
