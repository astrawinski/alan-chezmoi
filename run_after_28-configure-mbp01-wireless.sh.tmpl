{{- if eq .chezmoi.os "linux" -}}
{{- $linux := .packages.linux -}}
{{- $canonicalHostname := get ($linux.host_aliases | default dict) .chezmoi.hostname | default .chezmoi.hostname -}}
{{- if eq $canonicalHostname "wsub-mbp01" -}}
#!/bin/sh
set -eu

repo_dir="${HOME}/src/wsub"
secret_file="${repo_dir}/inventory/host_vars/wsub-mbp01.sops.yaml"
nm_file="/etc/NetworkManager/system-connections/snet-client.nmconnection"
wifi_device=""

if ! command -v sops >/dev/null 2>&1; then
  printf '[chezmoi] sops is not installed yet; skipping wsub-mbp01 Wi-Fi profile.\n'
  exit 0
fi

if ! command -v nmcli >/dev/null 2>&1; then
  printf '[chezmoi] NetworkManager is not installed yet; skipping wsub-mbp01 Wi-Fi profile.\n'
  exit 0
fi

if [ ! -f "${secret_file}" ]; then
  printf '[chezmoi] wsub checkout or host secret is not present yet; skipping wsub-mbp01 Wi-Fi profile.\n'
  exit 0
fi

if ! wifi_psk="$(sops --decrypt --extract '["unifi_wlan_home_passphrase"]' "${secret_file}" 2>/dev/null)"; then
  printf '[chezmoi] Could not decrypt wsub-mbp01 Wi-Fi secret yet; skipping profile render.\n'
  exit 0
fi

mkdir -p "${HOME}/.config/wsub/network"
tmp_file="${HOME}/.config/wsub/network/snet-client.nmconnection"
connection_uuid="$(python3 - <<'PY'
import uuid
print(uuid.uuid5(uuid.NAMESPACE_DNS, "wsub-mbp01:snet-client"))
PY
)"

cat > "${tmp_file}" <<EOF
[connection]
id=snet-client
uuid=${connection_uuid}
type=wifi
autoconnect=true

[802-11-wireless]
mode=infrastructure
ssid=snet-client

[802-11-wireless-security]
key-mgmt=wpa-psk
psk=${wifi_psk}

[ipv4]
method=auto

[ipv6]
addr-gen-mode=default
method=auto

[proxy]
EOF

sudo install -D -o root -g root -m 600 "${tmp_file}" "${nm_file}"
sudo nmcli connection reload >/dev/null

wifi_device="$(nmcli -t -f DEVICE,TYPE device status | awk -F: '$2 == "wifi" {print $1; exit}')"
if [ -n "${wifi_device}" ]; then
  nmcli connection up snet-client ifname "${wifi_device}" >/dev/null 2>&1 || true
fi

printf '[chezmoi] Ensured wsub-mbp01 Wi-Fi profile for snet-client.\n'
{{- end -}}
{{- end -}}
