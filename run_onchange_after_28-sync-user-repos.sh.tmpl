{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
set -eu

if [ ! -x "${HOME}/.local/bin/sync-user-repos" ]; then
  printf '[chezmoi] sync-user-repos is not installed yet; skipping repo sync.\n' >&2
  exit 0
fi

if ! "${HOME}/.local/bin/sync-user-repos"; then
  printf '[chezmoi] User repo sync did not complete during apply; continuing.\n' >&2
fi
{{ end -}}
