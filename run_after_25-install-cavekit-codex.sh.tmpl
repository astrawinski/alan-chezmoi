{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
set -eu

repo_dir="${HOME}/src/cavekit-codex"
state_dir="${HOME}/.local/state/chezmoi"
state_file="${state_dir}/cavekit-codex-installed-ref"

if [ ! -d "${repo_dir}/skills" ]; then
  if [ -x "${HOME}/.local/bin/sync-user-repos" ]; then
    printf '[chezmoi] cavekit-codex checkout is missing; syncing repos first.\n' >&2
    "${HOME}/.local/bin/sync-user-repos" || true
  fi
fi

if [ ! -d "${repo_dir}/skills" ]; then
  printf '[chezmoi] cavekit-codex skills surface is missing; skipping.\n' >&2
  exit 0
fi

current_ref=""
if [ -d "${repo_dir}/.git" ]; then
  current_ref="$(git -C "${repo_dir}" rev-parse HEAD 2>/dev/null || true)"
fi

needs_install=0
for skill_name in ck-backprop ck-build ck-caveman ck-check ck-spec; do
  if [ ! -f "${HOME}/.agents/skills/${skill_name}/SKILL.md" ] &&
     [ ! -f "${HOME}/.codex/skills/${skill_name}/SKILL.md" ]; then
    needs_install=1
    break
  fi
done

if [ "${needs_install}" -eq 0 ] && [ -n "${current_ref}" ] && [ -f "${state_file}" ]; then
  installed_ref="$(cat "${state_file}")"
  if [ "${installed_ref}" = "${current_ref}" ]; then
    printf '[chezmoi] cavekit-codex skills already installed for %s; skipping.\n' "${current_ref}" >&2
    exit 0
  fi
fi

if command -v skills >/dev/null 2>&1; then
  install_cmd='skills add'
elif command -v npx >/dev/null 2>&1; then
  install_cmd='npx --yes skills add'
elif command -v mise >/dev/null 2>&1; then
  install_cmd='mise exec node@latest -- npx --yes skills add'
else
  printf '[chezmoi] skills, npx, and mise are unavailable; skipping.\n' >&2
  exit 0
fi

printf '[chezmoi] Installing cavekit-codex skills into Codex from %s\n' "${repo_dir}" >&2
# shellcheck disable=SC2086
${install_cmd} "${repo_dir}" -g -a codex -y --skill '*'

if [ -n "${current_ref}" ]; then
  mkdir -p "${state_dir}"
  printf '%s\n' "${current_ref}" > "${state_file}"
fi
{{ end -}}
