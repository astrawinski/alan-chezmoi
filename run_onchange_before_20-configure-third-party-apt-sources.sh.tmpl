{{- if eq .chezmoi.os "linux" -}}
{{- $linux := .packages.linux -}}
{{- $canonicalHostname := get ($linux.host_aliases | default dict) .chezmoi.hostname | default .chezmoi.hostname -}}
{{- $host := get $linux.hosts $canonicalHostname | default dict -}}
{{- $aptGuiCommon := $linux.apt_gui_common | default (list) -}}
{{- $rolePackages := $linux.role_packages | default dict -}}
{{- $roles := get $host "roles" | default (list) -}}
{{- $aptExtra := get $host "apt_extra" | default (list) -}}
{{- $aptSourceComponentsExtra := get $host "apt_source_components_extra" | default (list) -}}
{{- $needsBrave := false -}}
{{- $needsCode := false -}}
{{- $needsSignal := false -}}
{{- $needsTerraform := false -}}
{{- range $aptGuiCommon }}
{{- if eq . "brave-browser" }}{{- $needsBrave = true -}}{{- end -}}
{{- if eq . "code" }}{{- $needsCode = true -}}{{- end -}}
{{- if eq . "signal-desktop" }}{{- $needsSignal = true -}}{{- end -}}
{{- end -}}
{{- range $roles }}
{{- $roleName := . -}}
{{- range (get $rolePackages $roleName | default (list)) }}
{{- if eq . "terraform" }}{{- $needsTerraform = true -}}{{- end -}}
{{- end -}}
{{- end -}}
{{- range $aptExtra }}
{{- if eq . "terraform" }}{{- $needsTerraform = true -}}{{- end -}}
{{- end -}}
{{- if or $needsBrave $needsCode $needsSignal $needsTerraform $aptSourceComponentsExtra -}}
#!/bin/sh
set -eu

{{- if $aptSourceComponentsExtra }}
sudo python3 - <<'PY'
from pathlib import Path

sources = Path("/etc/apt/sources.list")
if sources.exists():
    extras = {{ toJson $aptSourceComponentsExtra }}
    rewritten = []
    for raw_line in sources.read_text().splitlines():
        line = raw_line.rstrip("\n")
        stripped = line.strip()
        if stripped.startswith("deb ") or stripped.startswith("deb-src "):
            parts = line.split()
            if len(parts) >= 4 and parts[1].startswith("http://deb.debian.org/debian"):
                components = parts[3:]
                for extra in extras:
                    if extra not in components:
                        components.append(extra)
                line = " ".join(parts[:3] + components)
        rewritten.append(line)
    sources.write_text("\n".join(rewritten) + "\n")
PY
{{ end -}}

sudo apt-get update
sudo apt-get install -y ca-certificates curl gpg wget apt-transport-https

tmpdir="$(mktemp -d)"
trap 'rm -rf "${tmpdir}"' EXIT

{{- if $needsBrave }}
sudo curl -fsSLo /usr/share/keyrings/brave-browser-archive-keyring.gpg \
  https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg
sudo curl -fsSLo /etc/apt/sources.list.d/brave-browser-release.sources \
  https://brave-browser-apt-release.s3.brave.com/brave-browser.sources
{{ end -}}

{{- if $needsCode }}
wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor > "${tmpdir}/microsoft.gpg"
sudo install -D -o root -g root -m 644 "${tmpdir}/microsoft.gpg" /usr/share/keyrings/microsoft.gpg
cat <<'EOF' | sudo tee /etc/apt/sources.list.d/vscode.sources >/dev/null
Types: deb
URIs: https://packages.microsoft.com/repos/code
Suites: stable
Components: main
Architectures: amd64,arm64,armhf
Signed-By: /usr/share/keyrings/microsoft.gpg
EOF
{{ end -}}

{{- if $needsSignal }}
wget -qO- https://updates.signal.org/desktop/apt/keys.asc | gpg --dearmor > signal-desktop-keyring.gpg
sudo install -D -o root -g root -m 644 signal-desktop-keyring.gpg /usr/share/keyrings/signal-desktop-keyring.gpg
rm -f signal-desktop-keyring.gpg
wget -qO "${tmpdir}/signal-desktop.sources" https://updates.signal.org/static/desktop/apt/signal-desktop.sources
sudo install -D -o root -g root -m 644 "${tmpdir}/signal-desktop.sources" /etc/apt/sources.list.d/signal-desktop.sources
{{ end -}}
{{- if $needsTerraform }}
wget -qO- https://apt.releases.hashicorp.com/gpg | gpg --dearmor > "${tmpdir}/hashicorp.gpg"
sudo install -D -o root -g root -m 644 "${tmpdir}/hashicorp.gpg" /usr/share/keyrings/hashicorp-archive-keyring.gpg
. /etc/os-release
cat <<EOF | sudo tee /etc/apt/sources.list.d/hashicorp.sources >/dev/null
Types: deb
URIs: https://apt.releases.hashicorp.com
Suites: ${VERSION_CODENAME}
Components: main
Architectures: $(dpkg --print-architecture)
Signed-By: /usr/share/keyrings/hashicorp-archive-keyring.gpg
EOF
{{ end -}}
{{ end -}}
{{ end -}}
