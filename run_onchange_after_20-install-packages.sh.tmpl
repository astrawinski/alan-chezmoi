{{- if eq .chezmoi.os "linux" -}}
{{- $linux := .packages.linux -}}
{{- $host := get $linux.hosts .chezmoi.hostname | default dict -}}
{{- $desktopFamily := get $host "desktop_family" | default "none" -}}
{{- $desktopPackages := get $linux.desktop_packages $desktopFamily | default (list) -}}
{{- $aptCommon := $linux.apt_common | default (list) -}}
{{- $aptExtra := get $host "apt_extra" | default (list) -}}
{{- if or $aptCommon $desktopPackages $aptExtra -}}
#!/bin/sh
set -eu

sudo apt-get update
sudo apt-get install -y \
{{- range $aptCommon }}
  {{ . }} \
{{- end }}
{{- range $desktopPackages }}
  {{ . }} \
{{- end }}
{{- range $aptExtra }}
  {{ . }} \
{{- end }}

{{ end -}}
{{ end -}}
