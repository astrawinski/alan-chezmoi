{{- if eq .chezmoi.os "linux" -}}
{{- $linux := .packages.linux -}}
{{- $canonicalHostname := get ($linux.host_aliases | default dict) .chezmoi.hostname | default .chezmoi.hostname -}}
{{- $host := get $linux.hosts $canonicalHostname | default dict -}}
{{- $packageFamily := get $host "package_family" | default "apt" -}}
{{- $desktopFamily := get $host "desktop_family" | default "none" -}}
{{- $desktopPackages := get $linux.desktop_packages $desktopFamily | default (list) -}}
{{- $aptCoreCommon := $linux.apt_core_common | default (list) -}}
{{- $aptGuiCommon := $linux.apt_gui_common | default (list) -}}
{{- $rolePackages := $linux.role_packages | default dict -}}
{{- $roles := get $host "roles" | default (list) -}}
{{- $aptExtra := get $host "apt_extra" | default (list) -}}
{{- $externalBinaries := $linux.external_binaries | default dict -}}
{{- $pacmanCoreCommon := $linux.pacman_core_common | default (list) -}}
{{- $pacmanRolePackages := $linux.pacman_role_packages | default dict -}}
{{- $pacmanExtra := get $host "pacman_extra" | default (list) -}}
{{- if eq $packageFamily "apt" -}}
{{- if or $aptCoreCommon $aptGuiCommon $desktopPackages $roles $aptExtra -}}
#!/bin/sh
set -eu

sudo apt-get update
cat <<'EOF' | xargs sudo apt-get install -y
{{- range $aptCoreCommon }}
{{ . }}
{{- end }}
{{- range $aptGuiCommon }}
{{ . }}
{{- end }}
{{- range $desktopPackages }}
{{ . }}
{{- end }}
{{- range $roles }}
{{- $roleName := . -}}
{{- range (get $rolePackages $roleName | default (list)) }}
{{- if not (hasKey $externalBinaries .) }}
{{ . }}
{{- end }}
{{- end }}
{{- end }}
{{- range $aptExtra }}
{{- if not (hasKey $externalBinaries .) }}
{{ . }}
{{- end }}
{{- end }}
EOF

{{ end -}}
{{- else if eq $packageFamily "pacman" -}}
{{- if or $pacmanCoreCommon $roles $pacmanExtra -}}
#!/bin/sh
set -eu

if ! command -v pacman >/dev/null 2>&1; then
  printf '[chezmoi] pacman is not available; skipping Arch package install.\n' >&2
  exit 0
fi

for package_name in \
{{- range $pacmanCoreCommon }}
  {{ . | quote }} \
{{- end }}
{{- range $roles }}
{{- $roleName := . -}}
{{- range (get $pacmanRolePackages $roleName | default (list)) }}
  {{ . | quote }} \
{{- end }}
{{- end }}
{{- range $pacmanExtra }}
  {{ . | quote }} \
{{- end }}
; do
  if pacman -Q "${package_name}" >/dev/null 2>&1; then
    continue
  fi
  if ! pacman -Si "${package_name}" >/dev/null 2>&1; then
    if command -v yay >/dev/null 2>&1; then
      yay -S --needed --noconfirm "${package_name}" || {
        printf '[chezmoi] Arch/AUR package %s could not be installed; continuing.\n' "${package_name}" >&2
      }
      continue
    fi
    printf '[chezmoi] Arch package %s is not available in configured pacman repos; skipping.\n' "${package_name}" >&2
    continue
  fi
  sudo pacman -S --needed --noconfirm "${package_name}"
done
{{ end -}}
{{ end -}}
{{ end -}}
