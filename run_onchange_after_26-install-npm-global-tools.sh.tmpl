{{- if eq .chezmoi.os "linux" -}}
{{- $packages := .packages.linux.npm_global_tools | default (list) -}}
{{- if $packages -}}
#!/bin/sh
set -eu

if ! command -v npm >/dev/null 2>&1; then
  exit 0
fi

export NPM_CONFIG_PREFIX="${HOME}/.local/npm"
mkdir -p "${NPM_CONFIG_PREFIX}/bin"

for package_name in \
{{- range $packages }}
  {{ .name | quote }} \
{{- end }}
; do
  if npm -g ls --depth=0 "${package_name}" >/dev/null 2>&1; then
    continue
  fi

  npm -g install "${package_name}"
done
{{ end -}}
{{ end -}}
