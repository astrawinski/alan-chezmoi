#!/bin/sh
set -eu

if ! command -v lpass >/dev/null 2>&1; then
  printf '[chezmoi] LastPass CLI is not installed.\n' >&2
  exit 1
fi

if ! lpass status >/dev/null 2>&1; then
  printf '[chezmoi] LastPass is not logged in yet.\n' >&2
  exit 1
fi

usage() {
  cat <<'EOF'
usage: update-workstation-secrets <codex|onedrive|api-keys|all>

Push selected local secret-backed workstation state into the matching LastPass
entries under WSUB/.
EOF
}

update_note_item() {
  item_name="$1"
  source_file="$2"

  if [ ! -f "${source_file}" ]; then
    printf '[chezmoi] Missing local source file: %s\n' "${source_file}" >&2
    exit 1
  fi

  if lpass show --sync=now --quiet --color=never "${item_name}" >/dev/null 2>&1; then
    lpass edit --non-interactive --notes "${item_name}" < "${source_file}"
    printf '[chezmoi] Updated %s from %s\n' "${item_name}" "${source_file}"
  else
    lpass add --non-interactive --notes "${item_name}" < "${source_file}"
    printf '[chezmoi] Created %s from %s\n' "${item_name}" "${source_file}"
  fi
}

update_codex() {
  update_note_item "WSUB/secret-codex-auth" "${HOME}/.codex/auth.json"
}

update_onedrive() {
  item_name="WSUB/secret-onedrive-refresh-token"
  source_file="${HOME}/.config/onedrive/refresh_token"

  if [ ! -f "${source_file}" ]; then
    printf '[chezmoi] Missing local source file: %s\n' "${source_file}" >&2
    exit 1
  fi

  token="$(cat "${source_file}")"
  if [ -z "${token}" ]; then
    printf '[chezmoi] OneDrive refresh token file is empty: %s\n' "${source_file}" >&2
    exit 1
  fi

  if lpass show --sync=now --quiet --color=never "${item_name}" >/dev/null 2>&1; then
    printf '%s\n' "${token}" | lpass edit --non-interactive --password "${item_name}"
    printf '[chezmoi] Updated %s from %s\n' "${item_name}" "${source_file}"
  else
    printf '%s\n' "${token}" | lpass add --non-interactive --password "${item_name}"
    printf '[chezmoi] Created %s from %s\n' "${item_name}" "${source_file}"
  fi
}

update_api_keys() {
  update_note_item "WSUB/secret-api-keys" "${HOME}/.api_keys"
}

if [ "$#" -ne 1 ]; then
  usage >&2
  exit 1
fi

case "$1" in
  codex)
    update_codex
    ;;
  onedrive)
    update_onedrive
    ;;
  api-keys)
    update_api_keys
    ;;
  all)
    update_codex
    update_onedrive
    update_api_keys
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
