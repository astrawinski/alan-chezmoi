#!/bin/sh
set -eu

if [ $# -ne 1 ]; then
  printf 'Usage: ssh-refresh-host <host-or-fqdn>\n' >&2
  exit 1
fi

host="$1"
known_hosts_file="${HOME}/.config/wsub/ssh/known_hosts"

case "${host}" in
  *.*)
    fqdn="${host}"
    short_host="${host%%.*}"
    ;;
  *)
    short_host="${host}"
    fqdn="${host}.strawinski.net"
    ;;
esac

mkdir -p "$(dirname "${known_hosts_file}")"
touch "${known_hosts_file}"

ssh-keygen -f "${known_hosts_file}" -R "${short_host}" >/dev/null 2>&1 || true
ssh-keygen -f "${known_hosts_file}" -R "${fqdn}" >/dev/null 2>&1 || true

tmp_scan="$(mktemp)"
trap 'rm -f "${tmp_scan}"' EXIT

if ! ssh-keyscan -H "${fqdn}" > "${tmp_scan}" 2>/dev/null; then
  printf '[ssh-refresh-host] Failed to scan host key for %s.\n' "${fqdn}" >&2
  exit 1
fi

cat "${tmp_scan}" >> "${known_hosts_file}"
printf '[ssh-refresh-host] Refreshed host key for %s in %s.\n' "${fqdn}" "${known_hosts_file}"
