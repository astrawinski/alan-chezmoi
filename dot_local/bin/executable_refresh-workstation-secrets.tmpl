{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
set -eu

if ! command -v lpass >/dev/null 2>&1; then
  printf '[chezmoi] LastPass CLI is not installed.\n' >&2
  exit 1
fi

if ! lpass status >/dev/null 2>&1; then
  printf '[chezmoi] LastPass is not logged in yet.\n' >&2
  exit 1
fi

missing_items=""
lastpass_prefix="WSUB"

lastpass_item() {
  key="$1"
  case "${key}" in
    github_pat)
      printf '%s/%s\n' "${lastpass_prefix}" "secret-github-pat"
      ;;
    github_ssh)
      printf '%s/%s\n' "${lastpass_prefix}" "secret-github-ssh"
      ;;
    sops_age)
      printf '%s/%s\n' "${lastpass_prefix}" "secret-sops-age"
      ;;
    api_keys)
      printf '%s/%s\n' "${lastpass_prefix}" "secret-api-keys"
      ;;
    codex_auth)
      printf '%s/%s\n' "${lastpass_prefix}" "secret-codex-auth"
      ;;
    onedrive_refresh_token)
      printf '%s/%s\n' "${lastpass_prefix}" "secret-onedrive-refresh-token"
      ;;
    *)
      return 1
      ;;
  esac
}

require_lastpass_item() {
  key="$1"
  item_name="$(lastpass_item "${key}")"
  if ! lpass show --sync=now --quiet --color=never "${item_name}" >/dev/null 2>&1; then
    missing_items="${missing_items}\n- ${item_name}"
  fi
}

extract_note_field() {
  field="$1"
  note_file="$2"
  awk -v field="${field}" '
    $0 ~ ("^" field ":") {
      sub("^" field ": ?", "")
      print
      capture = 1
      next
    }
    capture && $0 ~ "^[A-Za-z0-9_]+:" {
      exit
    }
    capture {
      print
    }
  ' "${note_file}"
}

mkdir -p "${HOME}/.config/wsub/gh" "${HOME}/.config/sops/age" "${HOME}/.ssh" "${HOME}/.config/onedrive" "${HOME}/.codex"

require_lastpass_item github_pat
require_lastpass_item github_ssh
require_lastpass_item sops_age

if [ -n "${missing_items}" ]; then
  printf '[chezmoi] LastPass entries are still missing:%b\n' "${missing_items}" >&2
  exit 1
fi

github_ssh_item="$(lastpass_item github_ssh)"
sops_age_item="$(lastpass_item sops_age)"
github_pat_item="$(lastpass_item github_pat)"
github_token="$(lpass show --password "${github_pat_item}")"
cat > "${HOME}/.config/wsub/github-token.env" <<EOF
export GITHUB_TOKEN='${github_token}'
export GH_TOKEN='${github_token}'
EOF

cat > "${HOME}/.config/wsub/gh/hosts.yml" <<EOF
github.com:
    user: astrawinski
    oauth_token: '${github_token}'
    git_protocol: https
EOF

if api_keys_item="$(lastpass_item api_keys)" && lpass show --sync=now --quiet --color=never "${api_keys_item}" >/dev/null 2>&1; then
  lpass show --notes "${api_keys_item}" > "${HOME}/.api_keys"
fi

if codex_auth_item="$(lastpass_item codex_auth)" && lpass show --sync=now --quiet --color=never "${codex_auth_item}" >/dev/null 2>&1; then
  lpass show --notes "${codex_auth_item}" > "${HOME}/.codex/auth.json"
  chmod 600 "${HOME}/.codex/auth.json"
fi

if onedrive_refresh_token_item="$(lastpass_item onedrive_refresh_token)" && lpass show --sync=now --quiet --color=never "${onedrive_refresh_token_item}" >/dev/null 2>&1; then
  lpass show --password "${onedrive_refresh_token_item}" > "${HOME}/.config/onedrive/refresh_token"
  chmod 600 "${HOME}/.config/onedrive/refresh_token"
fi

github_ssh_note="$(mktemp)"
age_note="$(mktemp)"
trap 'rm -f "${github_ssh_note}" "${age_note}"' EXIT

lpass show --notes "${github_ssh_item}" > "${github_ssh_note}"
lpass show --notes "${sops_age_item}" > "${age_note}"

extract_note_field privateKey "${github_ssh_note}" > "${HOME}/.ssh/id_ed25519"
extract_note_field publicKey "${github_ssh_note}" > "${HOME}/.ssh/id_ed25519.pub"
cat > "${HOME}/.ssh/config" <<'EOF'
Include ~/.config/wsub/ssh/config

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
  StrictHostKeyChecking accept-new
EOF
extract_note_field privateKey "${age_note}" > "${HOME}/.config/sops/age/keys.txt"

chmod 700 "${HOME}/.ssh" "${HOME}/.config/sops/age"
chmod 600 "${HOME}/.ssh/id_ed25519" "${HOME}/.config/sops/age/keys.txt"
chmod 644 "${HOME}/.ssh/id_ed25519.pub" "${HOME}/.ssh/config" "${HOME}/.config/wsub/github-token.env" "${HOME}/.config/wsub/gh/hosts.yml"
if [ -f "${HOME}/.api_keys" ]; then
  chmod 644 "${HOME}/.api_keys"
fi

if [ -x "${HOME}/.local/bin/sync-user-repos" ]; then
  if ! "${HOME}/.local/bin/sync-user-repos"; then
    printf '[chezmoi] User repo sync did not complete after secret refresh.\n' >&2
  fi
fi

printf '[chezmoi] Refreshed LastPass-backed workstation secrets.\n'
{{ end -}}
