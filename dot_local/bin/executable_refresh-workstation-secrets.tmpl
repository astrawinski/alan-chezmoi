{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
set -eu

if ! command -v lpass >/dev/null 2>&1; then
  printf '[chezmoi] LastPass CLI is not installed.\n' >&2
  exit 1
fi

if ! lpass status >/dev/null 2>&1; then
  printf '[chezmoi] LastPass is not logged in yet.\n' >&2
  exit 1
fi

extract_note_field() {
  field="$1"
  note_file="$2"
  awk -v field="${field}" '
    $0 ~ ("^" field ":") {
      sub("^" field ": ?", "")
      print
      capture = 1
      next
    }
    capture && $0 ~ "^[A-Za-z0-9_]+:" {
      exit
    }
    capture {
      print
    }
  ' "${note_file}"
}

github_ssh_item="WSUB/secret-github-ssh"

if ! lpass show --sync=now --quiet --color=never "${github_ssh_item}" >/dev/null 2>&1; then
  printf '[chezmoi] Missing LastPass entry: %s\n' "${github_ssh_item}" >&2
  exit 1
fi

mkdir -p "${HOME}/.ssh"

github_ssh_note="$(mktemp)"
trap 'rm -f "${github_ssh_note}"' EXIT

lpass show --notes "${github_ssh_item}" > "${github_ssh_note}"

extract_note_field privateKey "${github_ssh_note}" > "${HOME}/.ssh/id_ed25519"
extract_note_field publicKey "${github_ssh_note}" > "${HOME}/.ssh/id_ed25519.pub"

cat > "${HOME}/.ssh/config" <<'EOF'
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519
  IdentitiesOnly yes
  StrictHostKeyChecking accept-new
EOF

chmod 700 "${HOME}/.ssh"
chmod 600 "${HOME}/.ssh/id_ed25519"
chmod 644 "${HOME}/.ssh/id_ed25519.pub" "${HOME}/.ssh/config"

printf '[chezmoi] Refreshed GitHub SSH key from LastPass.\n'
{{ end -}}
