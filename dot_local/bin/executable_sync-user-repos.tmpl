{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
set -eu

if ! command -v git >/dev/null 2>&1; then
  printf '[chezmoi] Git is not installed yet; skipping user repo sync.\n' >&2
  exit 0
fi

checkout_root="${HOME}/{{ .repos.checkout_root }}"
mkdir -p "${checkout_root}"

ensure_github_known_hosts() {
  known_hosts_file="${HOME}/.ssh/known_hosts"
  mkdir -p "${HOME}/.ssh"
  touch "${known_hosts_file}"

  if ssh-keygen -F github.com -f "${known_hosts_file}" >/dev/null 2>&1; then
    return 0
  fi

  if ! command -v ssh-keyscan >/dev/null 2>&1; then
    printf '[chezmoi] ssh-keyscan is not installed yet; skipping github.com known_hosts bootstrap.\n' >&2
    return 0
  fi

  if ssh-keyscan -H github.com >> "${known_hosts_file}" 2>/dev/null; then
    printf '[chezmoi] Seeded github.com host key into %s.\n' "${known_hosts_file}" >&2
  else
    printf '[chezmoi] Failed to preseed github.com host key; continuing.\n' >&2
  fi
}

github_https_fallback() {
  origin="$1"
  case "${origin}" in
    git@github.com:*.git)
      repo_path="${origin#git@github.com:}"
      printf 'https://github.com/%s\n' "${repo_path}"
      ;;
    *)
      return 1
      ;;
  esac
}

bootstrap_https_clone() {
  origin="$1"
  repo_dir="$2"
  GIT_TERMINAL_PROMPT=0 \
    git \
      -c credential.helper= \
      -c core.askPass= \
      -c credential.interactive=never \
      clone "${origin}" "${repo_dir}"
}

ensure_github_known_hosts

sync_repo() {
  name="$1"
  origin="$2"
  upstream="${3:-}"
  repo_dir="${checkout_root}/${name}"

  if [ -d "${repo_dir}/.git" ]; then
    current_origin="$(git -C "${repo_dir}" remote get-url origin 2>/dev/null || true)"
    if [ "${current_origin}" != "${origin}" ]; then
      fallback_origin="$(github_https_fallback "${origin}" || true)"
      if [ -n "${fallback_origin}" ] && [ "${current_origin}" = "${fallback_origin}" ]; then
        printf '[chezmoi] Repo %s still has bootstrap origin %s; restoring steady-state SSH origin %s.\n' "${name}" "${current_origin}" "${origin}" >&2
        git -C "${repo_dir}" remote set-url origin "${origin}"
      else
        printf '[chezmoi] Repo %s exists with unexpected origin %s; expected %s. Leaving it alone.\n' "${name}" "${current_origin:-<missing>}" "${origin}" >&2
        return 0
      fi
    fi
  else
    if [ -e "${repo_dir}" ]; then
      printf '[chezmoi] Repo path %s exists but is not a git checkout; leaving it alone.\n' "${repo_dir}" >&2
      return 0
    fi

    printf '[chezmoi] Cloning %s into %s\n' "${name}" "${repo_dir}"
    if ! git clone "${origin}" "${repo_dir}"; then
      fallback_origin="$(github_https_fallback "${origin}" || true)"
      if [ -z "${fallback_origin}" ]; then
        printf '[chezmoi] Failed to clone %s from %s.\n' "${name}" "${origin}" >&2
        return 1
      fi

      printf '[chezmoi] SSH clone for %s failed; retrying bootstrap clone over %s.\n' "${name}" "${fallback_origin}" >&2
      if ! bootstrap_https_clone "${fallback_origin}" "${repo_dir}"; then
        printf '[chezmoi] Failed to clone %s from %s and %s.\n' "${name}" "${origin}" "${fallback_origin}" >&2
        return 1
      fi

      git -C "${repo_dir}" remote set-url origin "${origin}"
    fi
  fi

  if [ -n "${upstream}" ]; then
    if git -C "${repo_dir}" remote get-url upstream >/dev/null 2>&1; then
      current_upstream="$(git -C "${repo_dir}" remote get-url upstream 2>/dev/null || true)"
      if [ "${current_upstream}" != "${upstream}" ]; then
        printf '[chezmoi] Repo %s has unexpected upstream %s; expected %s. Leaving it alone.\n' "${name}" "${current_upstream:-<missing>}" "${upstream}" >&2
      fi
    else
      git -C "${repo_dir}" remote add upstream "${upstream}"
    fi
  fi
}

sync_failed=0
{{- range .repos.managed }}
if ! sync_repo "{{ .name }}" "{{ .origin }}" "{{ if hasKey . "upstream" }}{{ index . "upstream" }}{{ end }}"; then
  sync_failed=1
fi
{{- end }}

if [ "${sync_failed}" -ne 0 ]; then
  exit 1
fi
{{ end -}}
