{{ if eq .chezmoi.os "linux" -}}
#!/bin/sh
set -eu

if ! command -v lpass >/dev/null 2>&1; then
  exit 0
fi

if ! lpass status >/dev/null 2>&1; then
  printf '[chezmoi] LastPass is not logged in yet; skipping secret rendering.\n' >&2
  exit 0
fi

missing_items=""

require_lastpass_item() {
  item_name="$1"
  if ! lpass show --sync=now --quiet --color=never "${item_name}" >/dev/null 2>&1; then
    missing_items="${missing_items}\n- ${item_name}"
  fi
}

extract_note_field() {
  field="$1"
  note_file="$2"
  awk -v field="${field}" '
    $0 ~ ("^" field ":") {
      sub("^" field ": ?", "")
      print
      capture = 1
      next
    }
    capture && $0 ~ "^[A-Za-z0-9_]+:" {
      exit
    }
    capture {
      print
    }
  ' "${note_file}"
}

mkdir -p "${HOME}/.config/wsub/gh" "${HOME}/.codex" "${HOME}/.ssh" "${HOME}/.config/sops/age"

require_lastpass_item 'GitHub Personal Access Token'
require_lastpass_item 'Codex Auth'
require_lastpass_item 'WSUB API Keys'
require_lastpass_item 'GitHub SSH Key'
require_lastpass_item 'SOPS Age Key'

if [ -n "${missing_items}" ]; then
  printf '[chezmoi] LastPass entries are still missing; skipping secret rendering:%b\n' "${missing_items}" >&2
  exit 0
fi

github_token="$(lpass show --password 'GitHub Personal Access Token')"
cat > "${HOME}/.config/wsub/github-token.env" <<EOF
export GITHUB_TOKEN='${github_token}'
export GH_TOKEN='${github_token}'
EOF

cat > "${HOME}/.config/wsub/gh/hosts.yml" <<EOF
github.com:
    user: {{ .github_user }}
    oauth_token: '${github_token}'
    git_protocol: https
EOF

lpass show --notes 'Codex Auth' > "${HOME}/.codex/auth.json"
lpass show --notes 'WSUB API Keys' > "${HOME}/.api_keys"

github_ssh_note="$(mktemp)"
age_note="$(mktemp)"
trap 'rm -f "${github_ssh_note}" "${age_note}"' EXIT

lpass show --notes 'GitHub SSH Key' > "${github_ssh_note}"
lpass show --notes 'SOPS Age Key' > "${age_note}"

extract_note_field privateKey "${github_ssh_note}" > "${HOME}/.ssh/id_ed25519"
extract_note_field publicKey "${github_ssh_note}" > "${HOME}/.ssh/id_ed25519.pub"
extract_note_field privateKey "${age_note}" > "${HOME}/.config/sops/age/keys.txt"

chmod 700 "${HOME}/.ssh" "${HOME}/.config/sops/age"
chmod 600 "${HOME}/.ssh/id_ed25519" "${HOME}/.config/sops/age/keys.txt"
chmod 644 "${HOME}/.ssh/id_ed25519.pub" "${HOME}/.config/wsub/github-token.env" "${HOME}/.config/wsub/gh/hosts.yml" "${HOME}/.codex/auth.json" "${HOME}/.api_keys"
{{ end -}}
